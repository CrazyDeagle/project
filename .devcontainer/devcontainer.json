{
  "name": "SilexCode (CUDA dev)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "runArgs": ["--gpus=all", "--shm-size=8g"],
  "remoteUser": "root",
  "workspaceFolder": "/workspace/silexcode",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/silexcode,type=bind,consistency=cached",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "nvidia.nsight-vscode-edition",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  },
  "postCreateCommand": "pip install -e .[dev] --no-build-isolation && pre-commit install"
}
